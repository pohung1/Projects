    {
      "cell_type": "code",
      "source": [
        "# Modelings\n",
        "\n",
        "#### Extra Trees ####\n",
        "etc = ExtraTreesClassifier(\n",
        "    n_estimators=1000,\n",
        "    max_depth=7,\n",
        "    min_samples_split=3,\n",
        "    min_samples_leaf=3,\n",
        "    max_features='sqrt',\n",
        "    random_state=42,\n",
        "    n_jobs=-1\n",
        ")\n",
        "\n",
        "etc.fit(X_train2, y_train2)\n",
        "\n",
        "\n",
        "#### Bagging ####\n",
        "base_tree = DecisionTreeClassifier(max_depth=6,\n",
        "                                   min_samples_leaf=2,\n",
        "                                   random_state=42)\n",
        "\n",
        "bagging_clf = BaggingClassifier(\n",
        "    base_tree,\n",
        "    n_estimators = 400,\n",
        "    max_samples = 0.85,\n",
        "    bootstrap=True,\n",
        "    oob_score=True,\n",
        "    n_jobs=-1,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "bagging_clf.fit(X_train2, y_train2)\n",
        "\n",
        "\n",
        "#### Pasting clf ####\n",
        "pasting_clf = BaggingClassifier(\n",
        "    base_tree,\n",
        "    n_estimators=300,\n",
        "    max_samples=0.8,\n",
        "    max_features=1.0,\n",
        "    bootstrap=False,\n",
        "    n_jobs=-1,\n",
        "    random_state=42\n",
        ")\n",
        "pasting_clf.fit(X_train2, y_train2)\n",
        "\n",
        "\n",
        "#### StackingClassifier ####\n",
        "# Caruana's Paper: use Logistic-Regression as meta-model\n",
        "# ETC + Bagging + Pasting --> Logistic Regression\n",
        "\n",
        "final_est = Pipeline([\n",
        "    ('scale', StandardScaler()),\n",
        "    ('lr', LogisticRegression(max_iter=1000))\n",
        "])\n",
        "\n",
        "estimators = [\n",
        "    ('etc', etc),\n",
        "    ('bagging_clf', bagging_clf),\n",
        "    # ('pasting_clf', pasting_clf)\n",
        "]\n",
        "\n",
        "stack = StackingClassifier(\n",
        "    estimators=estimators,\n",
        "    final_estimator=final_est,\n",
        "    passthrough=True,\n",
        "    cv=5,\n",
        "    n_jobs=-1\n",
        ")\n",
        "\n",
        "stack.fit(X_train2, y_train2)\n",
        "\n",
        "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
        "cv_score_etc = cross_val_score(etc, X2, y2, cv=cv, scoring='accuracy')\n",
        "cv_score_bag = cross_val_score(bagging_clf, X2, y2, cv=cv, scoring='accuracy')\n",
        "cv_score_pas = cross_val_score(pasting_clf, X2, y2, cv=cv, scoring='accuracy')\n",
        "cv_score_stack = cross_val_score(stack, X2, y2, cv=cv, scoring='accuracy')\n",
        "\n",
        "print('Extra Trees:', cv_score_etc.mean())\n",
        "print('Bagging:', cv_score_bag.mean())\n",
        "print('Pasting:', cv_score_pas.mean())\n",
        "print('Stacking:', cv_score_stack.mean())\n",
        "\n",
        "print('ETC:', etc.score(X_val2, y_val2))\n",
        "print('Bagging:', bagging_clf.score(X_val2, y_val2))\n",
        "print('Pasting:', pasting_clf.score(X_val2, y_val2))\n",
        "print('Stack:', stack.score(X_val2, y_val2))\n",
